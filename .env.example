# ============================================================
# Sylora — variáveis de ambiente
# Copia para .env e preenche. NUNCA commitar o .env.
# ============================================================

# Base de dados (docker-compose local: sylora-db / sylora_user / sylora_pass / sylora)
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=

# Aplicação
SITE_URL=http://localhost:8080
APP_ENV=development
PORT=8080

# Email (opcional em dev — escolhe Resend OU SMTP)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls
SMTP_FROM=noreply@sylora.lol
SMTP_FROM_NAME=Sylora

# reCAPTCHA v3 (opcional — sem chaves, a verificação fica desligada)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Save seguro — TEM de ser IDÊNTICO ao macro SAVE_SECRET no jogo (constants.gml).
# Gera com: openssl rand -hex 32   (ou PowerShell equivalente). NUNCA commitar.
SYLORA_SAVE_SECRET=
