RewriteEngine On
RewriteBase /

# =========================================
# Segurança
# =========================================

<FilesMatch "\.(env|log|sql|bak|backup|gitignore)$">
    Require all denied
</FilesMatch>

Options -Indexes

# =========================================
# Páginas de erro personalizadas
# =========================================

ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.clarity.ms https://www.clarity.ms https://www.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; media-src 'self'; connect-src 'self' https://*.clarity.ms https://m.clarity.ms https://c.bing.com https://www.google.com; frame-src 'self' https://www.google.com; worker-src 'self' blob:;"
</IfModule>

# =========================================
# Performance
# =========================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# =========================================
# Redirecionar apex → www
# =========================================

<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_HOST} ^sylora\.lol$ [NC]
    RewriteRule ^ https://www.sylora.lol%{REQUEST_URI} [L,R=301]
</IfModule>

# =========================================
# Redirects de URLs renomeados
# =========================================

<IfModule mod_rewrite.c>
    RewriteRule ^sobrenos/?$ /sobre [R=301,L]
    RewriteRule ^sobrenos\.php$ /sobre [R=301,L]
</IfModule>

# =========================================
# URLs amigáveis (sem extensão .php)
# =========================================

<IfModule mod_rewrite.c>
    # 1. Redirect /page.php para /page (exceto avatar.php)
    RewriteCond %{THE_REQUEST} \s/([^?\s]+)\.php[\s?]
    RewriteCond %1 !^avatar$
    RewriteRule ^ /%1 [R=301,L,NE]

    # 2. Internamente reescrever /page → page.php
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^.]+?)/?$ $1.php [L]
</IfModule>

# =========================================
# Charset e configurações gerais
# =========================================

AddDefaultCharset UTF-8
<IfModule mod_mime.c>
    AddCharset utf-8 .html .css .js .xml .json .rss .atom
</IfModule>

php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value session.gc_maxlifetime 1800
